<container direction="column" gap="5" padding="6" alignItems="center" backgroundColor="#000814" borderRadius="3" borderWidth="0.5" borderColor="#00e5ff">
  <text fontSize="7" fontWeight="bold" color="#00e5ff">DIFFICULTY</text>
  <container direction="column" gap="4" alignItems="center" padding="2">
    <text name="btn-easy" fontSize="5" color="#00ff88" backgroundColor="#003322" padding="3" borderRadius="2" borderWidth="0.3" borderColor="#00ff88" cursor="pointer">Easy - Slow AI</text>
    <text name="btn-medium" fontSize="5" color="#ffaa00" backgroundColor="#332200" padding="3" borderRadius="2" borderWidth="0.3" borderColor="#ffaa00" cursor="pointer">Medium - Balanced</text>
    <text name="btn-hard" fontSize="5" color="#ff4444" backgroundColor="#330000" padding="3" borderRadius="2" borderWidth="0.3" borderColor="#ff4444" cursor="pointer">Hard - Fast AI</text>
  </container>
  <text name="btn-back" fontSize="4" color="#ff4444" backgroundColor="#330000" padding="2" borderRadius="2" borderWidth="0.3" borderColor="#ff4444" cursor="pointer">BACK</text>
</container>
